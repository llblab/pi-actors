{
  "name": "@llblab/pi-actors",
  "version": "0.19.1",
  "private": false,
  "description": "Actor runtime and orchestrator for agent-managed local processes",
  "keywords": [
    "pi-package",
    "pi-extension",
    "actors",
    "orchestration",
    "automation",
    "tools"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/llblab/pi-actors.git"
  },
  "homepage": "https://github.com/llblab/pi-actors",
  "bugs": {
    "url": "https://github.com/llblab/pi-actors/issues"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "check": "node --experimental-strip-types -e \"await import('./index.ts'); console.log('pi-actors: extension import ok')\"",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "pack:dry": "npm pack --dry-run",
    "validate": "npx tsc --noEmit && npm run check && npm test && npm run pack:dry"
  },
  "files": [
    "index.ts",
    "lib",
    "scripts",
    "recipes",
    "skills",
    "README.md",
    "AGENTS.md",
    "BACKLOG.md",
    "CHANGELOG.md",
    "docs",
    "banner.jpg"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills/actors/SKILL.md",
      "./skills/swarm/SKILL.md"
    ],
    "image": "https://github.com/llblab/pi-actors/raw/main/banner.jpg"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  }
}
