{
  "async": true,
  "description": "Start a canonical mailbox-backed branch worker demo actor.",
  "args": [
    "repo:path",
    "branch:string",
    "poll_ms:int"
  ],
  "defaults": {
    "repo": "~/.pi/agent/extensions/pi-actors",
    "branch": "worker",
    "poll_ms": "1000"
  },
  "mailbox": {
    "accepts": [
      "task.assign",
      "control.stop",
      "control.cancel",
      "control.kill"
    ],
    "emits": [
      "actor.join",
      "task.claim",
      "task.result",
      "awaiting_assignment",
      "actor.leave",
      "run.done",
      "run.failed"
    ]
  },
  "artifacts": {
    "journal": "{state_dir}/worker-events.jsonl"
  },
  "template": "{repo}/scripts/actor-worker.mjs --state-dir {state_dir} --run {run_id} --branch {branch} --poll-ms {poll_ms}"
}
