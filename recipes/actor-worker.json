{
  "async": true,
  "description": "Start a canonical mailbox-backed branch worker demo actor.",
  "args": [
    "repo:path",
    "branch:string",
    "poll_ms:int",
    "stale_claim_ms:int",
    "write_artifacts:bool"
  ],
  "defaults": {
    "repo": "~/.pi/agent/extensions/pi-actors",
    "branch": "worker",
    "poll_ms": "1000",
    "stale_claim_ms": "0",
    "write_artifacts": "true"
  },
  "mailbox": {
    "accepts": [
      "task.assign",
      "control.kill"
    ],
    "emits": [
      "actor.join",
      "task.claim",
      "task.result",
      "awaiting_assignment",
      "actor.leave",
      "run.done",
      "run.failed"
    ]
  },
  "artifacts": {
    "journal": "{state_dir}/worker-events.jsonl",
    "status": "{state_dir}/worker-status.json",
    "results": "{state_dir}/worker-artifacts"
  },
  "template": "{repo}/scripts/actor-worker.mjs --state-dir {state_dir} --run {run_id} --branch {branch} --poll-ms {poll_ms} --stale-claim-ms {stale_claim_ms} --write-artifacts {write_artifacts}"
}
