{
  "async": true,
  "imports": {
    "normalizer": "subagent-normalize.json",
    "artifact": "subagent-artifact.json",
    "message": "utility-actor-message.json"
  },
  "args": [
    "input:string",
    "artifact_path:path",
    "artifact_format:string",
    "model:string",
    "tools:string"
  ],
  "defaults": {
    "artifact_format": "Markdown sections: Summary, Findings, Evidence, Risks, Next Actions.",
    "tools": ""
  },
  "mailbox": {
    "accepts": [
      "control.stop",
      "control.cancel",
      "control.kill"
    ],
    "emits": [
      "artifact.prepared",
      "artifact.blocked"
    ]
  },
  "template": [
    {
      "name": "normalizer",
      "values": {
        "input": "{input}",
        "format": "{artifact_format}",
        "model": "{model}",
        "tools": "{tools}"
      }
    },
    {
      "name": "artifact",
      "values": {
        "input": "Use normalized report from stdin.",
        "artifact_path": "{artifact_path}",
        "artifact_format": "{artifact_format}",
        "model": "{model}",
        "tools": "{tools}"
      }
    },
    {
      "name": "message",
      "values": {
        "type": "artifact.prepared",
        "summary": "Artifact prepared for path {artifact_path}."
      }
    }
  ]
}
