{
  "name": "pipeline-artifact-report",
  "async": true,
  "imports": {
    "normalizer": "subagent-normalize.json",
    "artifact": "subagent-artifact.json",
    "event": "utility-actor-message.json"
  },
  "args": [
    "input:string",
    "artifact_path:path",
    "artifact_format:string",
    "delivery:enum(log,notify,followup)",
    "model:string",
    "tools:string"
  ],
  "defaults": {
    "artifact_format": "Markdown sections: Summary, Findings, Evidence, Risks, Next Actions.",
    "delivery": "log",
    "model": "openai-codex/gpt-5.5",
    "tools": ""
  },
  "mailbox": {
    "emits": ["artifact.prepared", "artifact.blocked"]
  },
  "template": [
    {
      "name": "normalizer",
      "values": {
        "input": "{input}",
        "format": "{artifact_format}",
        "model": "{model}",
        "tools": "{tools}"
      }
    },
    {
      "name": "artifact",
      "values": {
        "input": "Use normalized report from stdin.",
        "artifact_path": "{artifact_path}",
        "artifact_format": "{artifact_format}",
        "model": "{model}",
        "tools": "{tools}"
      }
    },
    {
      "name": "event",
      "values": {
        "event_type": "artifact.prepared",
        "summary": "Artifact prepared for path {artifact_path}.",
        "delivery": "{delivery}"
      }
    }
  ]
}
