{
  "name": "pipeline-async-run-ops",
  "async": true,
  "imports": {
    "snapshot": "utility-run-ops-snapshot.json",
    "normalizer": "subagent-normalize.json",
    "artifact": "pipeline-artifact-report.json"
  },
  "args": [
    "state_root:path",
    "run_id:string",
    "lines:int",
    "stale_minutes:int",
    "artifact_path:path",
    "model:string",
    "tools:string"
  ],
  "defaults": {
    "state_root": "~/.pi/agent/tmp/pi-actors/runs",
    "run_id": "music",
    "lines": "80",
    "stale_minutes": "60",
    "artifact_path": "./async-run-ops.md",
    "tools": ""
  },
  "mailbox": {
    "accepts": [
      "control.stop",
      "control.cancel",
      "control.kill"
    ],
    "emits": [
      "operations.completed",
      "artifact.prepared",
      "command.done",
      "run.done",
      "run.failed"
    ]
  },
  "template": [
    {
      "name": "snapshot",
      "values": {
        "state_root": "{state_root}",
        "run_id": "{run_id}",
        "lines": "{lines}",
        "stale_minutes": "{stale_minutes}"
      }
    },
    {
      "name": "normalizer",
      "values": {
        "input": "Use actor run operations snapshot JSON from stdin. State root: {state_root}. Inspected run: {run_id}.",
        "format": "Markdown sections: Active Runs, Terminal Runs, Recent Actor Messages, Stale/Risky Runs, Recommended Controls, Follow-up Needed.",
        "model": "{model}",
        "thinking": "off",
        "tools": "{tools}"
      }
    },
    {
      "name": "artifact",
      "values": {
        "input": "Use normalized async-run operations report from stdin.",
        "artifact_path": "{artifact_path}",
        "artifact_format": "Markdown sections: Status, Actor Messages, Risks, Recommended Actions.",
        "model": "{model}",
        "tools": "{tools}"
      }
    }
  ]
}
