{
  "async": true,
  "imports": {
    "changelog": "utility-changelog-section.json",
    "package": "utility-package-summary.json",
    "skill": "utility-skill-summary.json",
    "validation": "utility-validation-wrapper.json",
    "review": "subagent-review-coordinator.json",
    "artifact": "pipeline-artifact-report.json"
  },
  "args": [
    "scope:path",
    "version:string",
    "package_json:path",
    "skill:path",
    "validation_command:string",
    "artifact_path:path",
    "lenses:array",
    "reviewer_model:string",
    "verifier_model:string",
    "merger_model:string",
    "judge_model:string",
    "thinking:string",
    "tools:string",
    "subagent_ttl_ms:int",
    "reviewer_concurrency:string",
    "min_successful_reviewers:int",
    "merge_policy:string"
  ],
  "defaults": {
    "scope": ".",
    "version": "0.15.0",
    "package_json": "{scope}/package.json",
    "skill": "{scope}/skills/actors/SKILL.md",
    "validation_command": "npm run validate",
    "artifact_path": "./release-readiness.md",
    "lenses": [
      "release",
      "package contents",
      "operator UX",
      "documentation",
      "packaged skills"
    ],
    "reviewer_model": "{current_model}",
    "verifier_model": "{current_model}",
    "merger_model": "{current_model}",
    "judge_model": "{current_model}",
    "thinking": "{current_thinking}",
    "tools": "",
    "subagent_ttl_ms": 600000,
    "reviewer_concurrency": "",
    "min_successful_reviewers": 1,
    "merge_policy": "Preserve partial reviewer reports, branch status, and degraded confidence markers. If reviewer evidence is below threshold, do not invent consensus."
  },
  "mailbox": {
    "accepts": [
      "control.kill"
    ],
    "emits": [
      "release.completed",
      "artifact.prepared",
      "command.done",
      "run.done",
      "run.failed"
    ]
  },
  "template": [
    {
      "name": "changelog",
      "values": {
        "file": "{scope}/CHANGELOG.md",
        "version": "{version}"
      }
    },
    {
      "name": "package",
      "values": {
        "package_json": "{package_json}",
        "repo": "{scope}"
      }
    },
    {
      "name": "skill",
      "values": {
        "skill": "{skill}",
        "package_json": "{package_json}",
        "repo": "{scope}"
      }
    },
    {
      "name": "validation",
      "values": {
        "scope": "{scope}",
        "command": "{validation_command}"
      }
    },
    {
      "name": "review",
      "values": {
        "scope": "Release scope {scope} for version {version}. Use changelog, package summary, packaged skill summary, and validation output from stdin.",
        "lenses": "{lenses}",
        "claim": "Version {version} is ready for release or the remaining blockers are explicitly identified.",
        "reviewer_model": "{reviewer_model}",
        "verifier_model": "{verifier_model}",
        "merger_model": "{merger_model}",
        "judge_model": "{judge_model}",
        "thinking": "{thinking}",
        "tools": "{tools}",
        "subagent_ttl_ms": "{subagent_ttl_ms}",
        "reviewer_concurrency": "{reviewer_concurrency}",
        "min_successful_reviewers": "{min_successful_reviewers}",
        "merge_policy": "{merge_policy}",
        "output_format": "Markdown sections: Status (complete/degraded/insufficient_data), Release Verdict, Blocking Issues, Package/Docs Risks, Validation Evidence, Publish Notes, Required Follow-up."
      }
    },
    {
      "name": "artifact",
      "values": {
        "input": "Use release readiness review from stdin.",
        "artifact_path": "{artifact_path}",
        "artifact_format": "Markdown sections: Release Verdict, Evidence, Risks, Checklist, Next Actions.",
        "model": "{merger_model}",
        "tools": "{tools}"
      }
    }
  ]
}
