{
  "async": true,
  "imports": {
    "coordinator": "subagent-review-coordinator.json"
  },
  "args": [
    "scope:string",
    "lenses:array",
    "release_gate:string",
    "reviewer_model:string",
    "verifier_model:string",
    "merger_model:string",
    "judge_model:string",
    "tools:string"
  ],
  "defaults": {
    "lenses": [
      "correctness",
      "tests",
      "release",
      "operator UX"
    ],
    "release_gate": "The scope is safe to ship or hand to the next release step.",
    "tools": ""
  },
  "mailbox": {
    "accepts": [
      "control.kill"
    ],
    "emits": [
      "review.completed",
      "pipeline.completed",
      "command.done",
      "run.done",
      "run.failed"
    ]
  },
  "template": {
    "name": "coordinator",
    "values": {
      "scope": "{scope}",
      "lenses": "{lenses}",
      "claim": "{release_gate}",
      "reviewer_model": "{reviewer_model}",
      "verifier_model": "{verifier_model}",
      "merger_model": "{merger_model}",
      "judge_model": "{judge_model}",
      "tools": "{tools}",
      "output_format": "Markdown sections: Ship Verdict, Blocking Findings, Nonblocking Risks, Evidence, Required Follow-up."
    }
  }
}
