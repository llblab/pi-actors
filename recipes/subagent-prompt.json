{
  "name": "subagent-prompt",
  "async": true,
  "args": [
    "prompt:string",
    "model:string",
    "thinking:string",
    "tool_args:string",
    "output_format:string"
  ],
  "defaults": {
    "model": "openai-codex/gpt-5.5",
    "thinking": "off",
    "tool_args": "--no-tools",
    "output_format": "Concise Markdown with assumptions and next actions."
  },
  "template": "pi -p --model {model} --thinking {thinking} {tool_args} {prompt}. Output format: {output_format}"
}
