{
  "name": "subagent-quorum",
  "async": true,
  "imports": {
    "subagent": "subagent-prompt.json"
  },
  "args": [
    "prompt:string",
    "models:array",
    "thinking:string",
    "tools:string",
    "output_format:string"
  ],
  "defaults": {
    "thinking": "off",
    "tools": "",
    "output_format": "Vote-style Markdown: Verdict, Rationale, Evidence, Confidence."
  },
  "mailbox": {
    "accepts": [
      "control.stop",
      "control.cancel",
      "control.kill"
    ],
    "emits": [
      "command.done",
      "run.done",
      "run.failed"
    ]
  },
  "repeat": "{models.length}",
  "parallel": true,
  "failure": "branch",
  "template": {
    "name": "subagent",
    "values": {
      "prompt": "{prompt}",
      "model": "{models[index]}",
      "thinking": "{thinking}",
      "tools": "{tools}",
      "output_format": "{output_format}"
    }
  }
}
