{
  "async": true,
  "args": [
    "prompt:string",
    "tools:string",
    "model:string",
    "thinking:string",
    "output_format:string"
  ],
  "defaults": {
    "thinking": "off",
    "output_format": "Concise Markdown with assumptions and next actions."
  },
  "mailbox": {
    "accepts": [
      "control.stop",
      "control.cancel",
      "control.kill"
    ],
    "emits": [
      "command.done",
      "run.done",
      "run.failed"
    ]
  },
  "template": "pi -p --model {model} --thinking {thinking} --tools {tools} {prompt}. Output format: {output_format}"
}
