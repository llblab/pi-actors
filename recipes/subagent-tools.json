{
  "name": "subagent-tools",
  "async": true,
  "args": [
    "prompt:string",
    "tools:string",
    "model:string"
  ],
  "defaults": {
    "model": "openai-codex/gpt-5.5"
  },
  "mailbox": {
    "accepts": ["control.stop"],
    "emits": ["command.done", "run.done", "run.failed"]
  },
  "template": "pi -p --model {model} --tools {tools} {prompt}"
}
