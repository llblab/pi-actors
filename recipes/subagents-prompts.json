{
  "name": "subagents-prompts",
  "async": true,
  "imports": {
    "subagent": "subagent-prompt.json"
  },
  "args": [
    "prompts:array"
  ],
  "repeat": "{prompts.length}",
  "parallel": true,
  "failure": "branch",
  "template": {
    "name": "subagent",
    "values": {
      "prompt": "{prompts[index]}"
    }
  }
}
