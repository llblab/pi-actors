{
  "name": "subagents-prompts",
  "async": true,
  "imports": {
    "subagent": "subagent-prompt.json"
  },
  "args": [
    "prompts:array",
    "model:string",
    "thinking:string",
    "tools:string",
    "output_format:string",
    "report_path:path",
    "summary_path:path"
  ],
  "defaults": {
    "thinking": "off",
    "tools": "",
    "output_format": "Concise Markdown with assumptions and next actions.",
    "report_path": "{state_dir}/stdout.log",
    "summary_path": "{state_dir}/result.json"
  },
  "artifacts": {
    "report": "{report_path}",
    "summary": "{summary_path}"
  },
  "mailbox": {
    "accepts": [
      "control.stop",
      "control.cancel",
      "control.kill"
    ],
    "emits": [
      "command.done",
      "run.done",
      "run.failed"
    ]
  },
  "repeat": "{prompts.length}",
  "parallel": true,
  "failure": "branch",
  "template": {
    "name": "subagent",
    "values": {
      "prompt": "{prompts[index]}",
      "model": "{model}",
      "thinking": "{thinking}",
      "tools": "{tools}",
      "output_format": "{output_format}"
    }
  }
}
