{
  "name": "utility-actor-message",
  "async": false,
  "args": [
    "event_type:string",
    "delivery:enum(log,notify,followup)",
    "to:string",
    "from:string",
    "summary:string",
    "metadata:string",
    "correlation_id:string",
    "reply_to:string",
    "repo:path"
  ],
  "defaults": {
    "delivery": "log",
    "to": "coordinator",
    "from": "run:{run_id}",
    "summary": "",
    "metadata": "{}",
    "correlation_id": "",
    "reply_to": "",
    "repo": "~/.pi/agent/extensions/pi-auto-tools"
  },
  "template": "node {repo}/scripts/recipe-utils.mjs actor-message {event_type} {delivery} {to} {from} {summary} {metadata} {correlation_id} {reply_to}"
}
