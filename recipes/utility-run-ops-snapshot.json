{
  "name": "utility-run-ops-snapshot",
  "args": [
    "repo:path",
    "state_root:path",
    "run_id:string",
    "lines:int",
    "stale_minutes:int"
  ],
  "defaults": {
    "repo": "~/.pi/agent/extensions/pi-actors",
    "state_root": "~/.pi/agent/tmp/pi-actors/runs",
    "run_id": "music",
    "lines": "80",
    "stale_minutes": "60"
  },
  "template": "{repo}/scripts/recipe-utils.mjs run-ops-snapshot {state_root} {run_id} {lines} {stale_minutes}"
}
